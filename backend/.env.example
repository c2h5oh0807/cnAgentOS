APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./data/cnagentos.db
CSRF_SECRET=replace-with-a-long-random-local-development-secret
SESSION_HOURS=8
COOKIE_SECURE=false

# Multi-database configuration (Phase 5)
ACTIVE_DATABASE=sqlite
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=cnagentos
MYSQL_PASSWORD=cnagentos_pass_here
MYSQL_DATABASE=cnagentos
